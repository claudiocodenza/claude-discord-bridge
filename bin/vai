#!/usr/bin/env bash
#
# vai - Start/manage the Claude-Discord Bridge
#

# Get toolkit root directory
TOOLKIT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export TOOLKIT_ROOT

# Use venv python if available
PYTHON="${TOOLKIT_ROOT}/.venv/bin/python3"
if [ ! -f "$PYTHON" ]; then
    PYTHON="python3"
fi

exec "$PYTHON" "${TOOLKIT_ROOT}/bin/_vai.py" "$@"
