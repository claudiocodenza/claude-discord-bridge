#!/usr/bin/env bash
#
# progress-hook — Claude Code PostToolUse hook
# Sends one-line tool use updates to Discord as Claude works.
# Rate-limited to 1 update per 3 seconds.
#

set -euo pipefail

CHANNEL_ID="${DISCORD_CHANNEL_ID:-}"
[ -z "$CHANNEL_ID" ] && exit 0

# Rate limit: 1 update per 3 seconds
RATE_FILE="/tmp/claude-progress-${CHANNEL_ID}.last"
NOW=$(date +%s)
if [ -f "$RATE_FILE" ]; then
    LAST=$(cat "$RATE_FILE" 2>/dev/null || echo 0)
    [ $((NOW - LAST)) -lt 3 ] && exit 0
fi

INPUT=$(cat)
TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty')
[ -z "$TOOL_NAME" ] && exit 0

ENV_FILE="${HOME}/.claude-discord-bridge/.env"
[ ! -f "$ENV_FILE" ] && exit 0
BOT_TOKEN=$(grep '^DISCORD_BOT_TOKEN=' "$ENV_FILE" | cut -d'=' -f2-)
[ -z "$BOT_TOKEN" ] && exit 0

# Format message by tool type
case "$TOOL_NAME" in
    Read)
        F=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')
        MSG="> :mag: Reading \`$(basename "$F")\`" ;;
    Edit)
        F=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')
        MSG="> :pencil2: Edited \`$(basename "$F")\`" ;;
    Write)
        F=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')
        MSG="> :page_facing_up: Wrote \`$(basename "$F")\`" ;;
    Bash)
        CMD=$(echo "$INPUT" | jq -r '.tool_input.command // empty')
        echo "$CMD" | grep -qE '^\s*dp\s' && exit 0
        CMD=$(echo "$CMD" | head -c 80 | sed 's/`/\\`/g')
        MSG="> :desktop: Ran \`${CMD}\`" ;;
    Grep)
        P=$(echo "$INPUT" | jq -r '.tool_input.pattern // empty' | head -c 60)
        MSG="> :mag_right: Searched for \`${P}\`" ;;
    Glob)
        P=$(echo "$INPUT" | jq -r '.tool_input.pattern // empty')
        MSG="> :file_folder: Globbing \`${P}\`" ;;
    WebFetch)
        U=$(echo "$INPUT" | jq -r '.tool_input.url // empty' | head -c 80)
        MSG="> :globe_with_meridians: Fetched ${U}" ;;
    WebSearch)
        Q=$(echo "$INPUT" | jq -r '.tool_input.query // empty' | head -c 80)
        MSG="> :mag: Searched: \`${Q}\`" ;;
    Agent)
        D=$(echo "$INPUT" | jq -r '.tool_input.description // empty' | head -c 80)
        MSG="> :robot: Agent: ${D}" ;;
    mcp__linear__*)
        MSG="> :clipboard: Linear: \`${TOOL_NAME#mcp__linear__}\`" ;;
    mcp__*)
        MSG="> :electric_plug: MCP: \`${TOOL_NAME}\`" ;;
    TaskCreate|TaskUpdate|TaskList|TaskGet)
        exit 0 ;;
    *)
        MSG="> :gear: ${TOOL_NAME}" ;;
esac

curl -s -o /dev/null -X POST "https://discord.com/api/v10/channels/${CHANNEL_ID}/messages" \
    -H "Authorization: Bot ${BOT_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg content "$MSG" '{content: $content}')" &

echo "$NOW" > "$RATE_FILE"
